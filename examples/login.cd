<!cd>
<cd>
<head>
    <title>Login</title>
    <link codex href="auth.codex"></link>
</head>

<body>
    <h1>Login</h1>

    <form action="/login" method="post">

        <label>Username</label>
        <input name="username" type="text" />

        <label>Password</label>
        <input name="password" type="password" />

        <button type="submit">Login</button>

    </form>
</body>
</cd>
